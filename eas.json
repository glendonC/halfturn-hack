{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_VISION": "1"
      },
      "ios": {
        "image": "macos-sequoia-15.6-xcode-16.4"
      }
    },
    "preview": {
      "extends": "development",
      "developmentClient": false
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
