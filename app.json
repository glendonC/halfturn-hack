{
  "expo": {
    "name": "HalfTurn",
    "slug": "halfturn-hack",
    "version": "1.0.0",
    "scheme": "halfturn",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0B0F14",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.halfturn.hack"
    },
    "android": {
      "package": "com.halfturn.hack",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#0B1F17",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0F14",
          "resizeMode": "contain",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "HalfTurn uses the camera to verify your turns in Turn & React mode. Video is processed on-device only and never leaves your phone.",
          "enableMicrophonePermission": false,
          "enableLocation": false,
          "enableCodeScanner": false,
          "enableFrameProcessors": true
        }
      ],
      [
        "react-native-mediapipe-posedetection",
        {
          "assetsPaths": [
            "./assets/models/"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "icon": "./assets/images/icon.png"
  }
}
