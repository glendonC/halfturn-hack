{
  "expo": {
    "name": "HalfTurn",
    "slug": "halfturn-hack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "halfturn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.halfturn.hack"
    },
    "android": {
      "package": "com.halfturn.hack",
      "adaptiveIcon": {
        "backgroundColor": "#0B1F17",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1F17"
        }
      ],
      "expo-audio",
      "expo-sqlite",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "HalfTurn uses the camera to verify your turns in Turn & React mode. Video is processed on-device only and never leaves your phone.",
          "enableMicrophonePermission": false,
          "enableLocation": false,
          "enableCodeScanner": false,
          "enableFrameProcessors": true
        }
      ],
      [
        "react-native-mediapipe-posedetection",
        {
          "assetsPaths": ["./assets/models/"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
