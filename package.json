{
  "name": "halfturn-hack",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "jest",
    "guard:expo-go": "bash scripts/guard-expo-go.sh",
    "fix-deps": "expo install --fix",
    "fetch-model": "bash scripts/fetch-pose-model.sh",
    "patch-native": "bash scripts/patch-native.sh",
    "postinstall": "bash scripts/patch-native.sh; bash scripts/fetch-pose-model.sh || echo 'pose model not fetched; run: npm run fetch-model'"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@react-native-community/slider": "5.0.1",
    "expo": "54.0.35",
    "expo-audio": "~1.1.1",
    "expo-blur": "~15.0.8",
    "expo-brightness": "~14.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-glass-effect": "~0.1.10",
    "expo-haptics": "~15.0.8",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-screen-orientation": "~9.0.9",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "lucide-react-native": "^1.24.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-mediapipe-posedetection": "0.4.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-vision-camera": "4.7.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets-core": "1.6.3",
    "react-refresh": "^0.14.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-arrow-functions": "^8.0.1",
    "@babel/plugin-transform-shorthand-properties": "^8.0.1",
    "@babel/plugin-transform-template-literals": "^8.0.1",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "~5.9.2"
  }
}
